#!/usr/bin/env zsh

[[ -v _z4h_tty_fd ]] || return

builtin echoti civis >&$_z4h_tty_fd
local -i cursor_x cursor_y
local -i line_count i
-z4h-get-cursor-pos || cursor_y=0
local clear=
# Match the soft-bottom implementation so both widgets stay accepted by
# `zsh -n` while preserving the amount of terminal padding they emit.
line_count=$((2 * LINES - cursor_y))
for (( i = 0; i < line_count; ++i )); do
  clear+=$'\n'
done
builtin print -rnu $_z4h_tty_fd -- $clear$'\e[H\e[2J'
builtin zle .reset-prompt
builtin zle -R
-z4h-cursor-show
